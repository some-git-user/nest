{
  "name": "nest",
  "version": "0.0.1",
  "description": "Nagios Rest Server",
  "main": "dist/server.js",
  "scripts": {
    "build": "npx tsc",
    "build:release": "npx tsc && esbuild dist/src/server.js --bundle --platform=node --outfile=standalone/server-bundled.js && node --experimental-sea-config sea-config.json && cp \"$(which node)\" standalone/node && cd standalone && cp node nest && npx postject nest NODE_SEA_BLOB sea-prep.blob --sentinel-fuse NODE_SEA_FUSE_fce680ab2cc467b6e072b8b5df1996b2 && rm -rf sea-prep.blob && rm -rf node && rm -rf server-bundled.js",
    "start": "node dist/server.js",
    "dev": "nodemon -r tsconfig-paths/register src/server.ts --inspect",
    "lint": "npx eslint . --ext .ts --fix",
    "format": "npx prettier --write .",
    "check:vulnerabilities": "npm audit --omit=dev"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/some-git-user/nest.git"
  },
  "author": "Viktor Dembizki",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/some-git-user/nest/issues"
  },
  "homepage": "https://github.com/some-git-user/nest#readme",
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "esbuild": "0.25.11",
    "eslint": "^9.38.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-promise": "^7.2.1",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "envalid": "^8.1.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "http-errors": "^2.0.0",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "xss-clean": "^0.1.4"
  }
}
